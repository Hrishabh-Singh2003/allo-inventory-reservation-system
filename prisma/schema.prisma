datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ReservationStatus {
  PENDING     // Reservation holds inventory temporarily
  CONFIRMED   // Reservation finalized, inventory permanently deducted
  RELEASED    // Reservation manually cancelled, inventory restored
  EXPIRED     // Reservation timed out, inventory automatically restored
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventories      Inventory[]
  reservationItems ReservationItem[]

  @@index([sku])
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories      Inventory[]
  reservationItems ReservationItem[]

  @@index([code])
}

model Inventory {
  id               String   @id @default(uuid())
  productId        String
  warehouseId      String
  totalQuantity    Int      // Total physical items in stock
  reservedQuantity Int      @default(0) // Quantity locked by pending reservations
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  
  // Strong database integrity linking directly to reservation items
  reservationItems ReservationItem[]

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

model Reservation {
  id            String            @id @default(uuid())
  status        ReservationStatus @default(PENDING)
  expiresAt     DateTime          // Timestamp when the reservation expires
  confirmedAt   DateTime?         // Nullable: populated when confirmed
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  items         ReservationItem[]

  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
}

model ReservationItem {
  id            String   @id @default(uuid())
  reservationId String
  productId     String
  warehouseId   String
  quantity      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  
  // Highly optimized database integrity constraint:
  // Direct relational link to the specific Inventory row
  inventory   Inventory   @relation(fields: [productId, warehouseId], references: [productId, warehouseId], onDelete: Restrict)

  @@index([reservationId])
  @@index([productId, warehouseId])
}
