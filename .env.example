# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Neon Serverless PostgreSQL)
# -----------------------------------------------------------------------------
# DATABASE_URL: Connects to Neon database.
# Optimized for serverless Next.js functions via Vercel.
# Note: append ?sslmode=require or configure pool settings as needed.
DATABASE_URL="postgres://[username]:[password]@[neon-project-id]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require"

# -----------------------------------------------------------------------------
# SECURITY & CRON SECRETS
# -----------------------------------------------------------------------------
# Secure random string used to validate headers on /api/reservations/cleanup
CRON_SECRET="generate-a-secure-random-key-here"

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (Idempotency Store)
# -----------------------------------------------------------------------------
# Used to cache idempotent API responses and prevent duplicate reservations.
#
# Standard Redis connection string (TCP/TLS) used by ioredis client:
REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"

# Upstash REST credentials (used by HTTP-based Upstash Redis clients):
UPSTASH_REDIS_REST_URL="https://<host>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<token>"

