# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# DATABASE_URL: Connects to the Supabase connection pooler on port 6543 (Transaction Mode).
# Optimized for serverless Next.js functions via Vercel.
# Note: Always include ?pglimit=1&supavisor=true&pool_timeout=10 to manage connection pools.
DATABASE_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pglimit=1&supavisor=true&pool_timeout=10"

# DIRECT_URL: Bypasses the connection pooler and connects directly to the DB on port 5432.
# Required for running Prisma migrations.
DIRECT_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# SECURITY & CRON SECRETS
# -----------------------------------------------------------------------------
# Secure random string used to validate headers on /api/reservations/cleanup
CRON_SECRET="generate-a-secure-random-key-here"

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (Idempotency Store)
# -----------------------------------------------------------------------------
# Used to cache idempotent API responses and prevent duplicate reservations.
#
# Standard Redis connection string (TCP/TLS) used by ioredis client:
REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"

# Upstash REST credentials (used by HTTP-based Upstash Redis clients):
UPSTASH_REDIS_REST_URL="https://<host>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<token>"

# -----------------------------------------------------------------------------
# RUNTIME ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV="development"
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
